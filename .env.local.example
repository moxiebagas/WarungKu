# Supabase
# Project URL, e.g. https://xxxxxxxx.supabase.co
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
# Anon public key (safe for client, currently unused but kept per spec)
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — SERVER ONLY. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Fonnte WhatsApp gateway
# Device token from https://md.fonnte.com/
FONNTE_TOKEN=

# WhatsApp group target for daily summaries and low-stock alerts.
# Use the Fonnte group id, e.g. 120363012345678901@g.us
WHATSAPP_GROUP_ID=

# Secret protecting the daily-summary cron endpoint. Vercel Cron sends this
# automatically as `Authorization: Bearer <CRON_SECRET>` when set here.
CRON_SECRET=

# Optional: allow OUT movements to push stock below zero (default false)
ALLOW_NEGATIVE_STOCK=false
